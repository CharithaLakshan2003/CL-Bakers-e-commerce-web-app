generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

//
// ─── ENUMS ─────────────────────────────────────────────
//

enum Role {
  VISITOR
  CUSTOMER
  BAKER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  BAKING
  READY_FOR_PICKUP
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}

enum DiscountType {
  PERCENT
  FIXED
}

enum CakeRequestStatus {
  PENDING
  QUOTED
  APPROVED
  REJECTED
}

enum Category {
  bread
  pastry
  cake
  savory
  gluten_free
}

enum Allergen {
  gluten
  dairy
  nuts
  eggs
  soy
  sesame
}

//
// ─── USER ─────────────────────────────────────────────
//

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  role           Role     @default(CUSTOMER)
  phone          String?
  birthday       DateTime?
  loyaltyPoints  Int      @default(0)
  emailVerified  DateTime?
  password       String?
  image          String?
  createdAt      DateTime @default(now())

  addresses      Address[]
  orders         Order[]
  reviews        Review[]
  cakeRequests   CustomCakeRequest[]
  accounts       Account[]
  sessions       Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//
// ─── ADDRESS ──────────────────────────────────────────
//

model Address {
  id                 String  @id @default(cuid())
  userId             String
  street             String
  city               String
  postalCode         String
  country            String
  isDefaultShipping  Boolean @default(false)
  isDefaultBilling   Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
  orders Order[]
}

//
// ─── PRODUCT ──────────────────────────────────────────
//

model Product {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String
  price           Float
  comparePrice    Float?
  stock           Int
  category        Category
  images          String[]   // stored as JSON (Postgres) or text array
  allergens       Allergen[]
  isActive        Boolean   @default(true)
  isTodaySpecial  Boolean   @default(false)
  seoTitle        String?
  seoDesc         String?
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  createdAt       DateTime  @default(now())

  nutritionalInfo NutritionalInfo?
  reviews         Review[]
  orderItems      OrderItem[]
}

//
// ─── NUTRITION (1:1 relation) ─────────────────────────
//

model NutritionalInfo {
  id        String  @id @default(cuid())
  productId String  @unique
  calories  Int
  protein   String
  carbs     String
  fat       String
  fiber     String
  sugar     String
  sodium    String

  product Product @relation(fields: [productId], references: [id])
}

//
// ─── ORDER ───────────────────────────────────────────
//

model Order {
  id                 String   @id @default(cuid())
  userId             String
  status             OrderStatus
  total              Float
  subtotal           Float
  tax                Float
  shippingFee        Float
  discount           Float
  couponCode         String?
  deliveryMethod     DeliveryMethod
  pickupBranch       String?
  pickupTimeSlot     String?
  specialInstructions String?
  paymentIntentId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  addressId   String?
  address     Address?  @relation(fields: [addressId], references: [id])

  items       OrderItem[]
}

//
// ─── ORDER ITEM ───────────────────────────────────────
//

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  productId     String
  productName   String
  productImage  String
  quantity      Int
  priceAtTime   Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

//
// ─── REVIEW ──────────────────────────────────────────
//

model Review {
  id               String   @id @default(cuid())
  userId           String
  productId        String
  rating           Int
  comment          String
  images           String[]
  verifiedPurchase Boolean  @default(false)
  createdAt        DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

//
// ─── COUPON ──────────────────────────────────────────
//

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountType    DiscountType
  discountValue   Float
  minOrderAmount  Float
  maxUsage        Int
  usedCount       Int      @default(0)
  expiresAt       DateTime
  isActive        Boolean  @default(true)
}

//
// ─── CUSTOM CAKE REQUEST ─────────────────────────────
//

model CustomCakeRequest {
  id             String   @id @default(cuid())
  userId         String?
  cakeType       String
  size           String
  servings       Int
  flavor         String
  filling        String
  frostingType   String
  frostingColor  String
  designText     String?
  designImages   String[]
  eventDate      DateTime
  deliveryMethod DeliveryMethod
  budget         String
  status         CakeRequestStatus @default(PENDING)

  user User? @relation(fields: [userId], references: [id])
}